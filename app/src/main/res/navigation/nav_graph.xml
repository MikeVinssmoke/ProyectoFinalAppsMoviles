<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.romero.proyectofinalappsmoviles.ui.splash.SplashFragment"
        android:label="Splash">
        <action
            android:id="@+id/action_splash_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_splash_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.romero.proyectofinalappsmoviles.ui.home.HomeFragment"
        android:label="Inicio">
        <action android:id="@+id/action_home_to_createReport"
            app:destination="@id/createReportFragment" />
        <action android:id="@+id/action_home_to_reportList"
            app:destination="@id/reportListFragment" />
        <action android:id="@+id/action_home_to_sync"
            app:destination="@id/syncStatusFragment" />
    </fragment>

    <fragment
        android:id="@+id/reportListFragment"
        android:name="com.example.romero.proyectofinalappsmoviles.ui.reports.ReportListFragment"
        android:label="Reportes">
        <action android:id="@+id/action_reportList_to_reportDetail"
            app:destination="@id/reportDetailFragment" />
        <action android:id="@+id/action_reportList_to_createReport"
            app:destination="@id/createReportFragment" />
    </fragment>

    <fragment
        android:id="@+id/reportDetailFragment"
        android:name="com.example.romero.proyectofinalappsmoviles.ui.reports.ReportDetailFragment"
        android:label="Detalle">
        <argument
            android:name="reportId"
            app:argType="long" />
        <action android:id="@+id/action_reportDetail_to_editReport"
            app:destination="@id/editReportFragment" />
    </fragment>

    <fragment
        android:id="@+id/createReportFragment"
        android:name="com.example.romero.proyectofinalappsmoviles.ui.reports.CreateReportFragment"
        android:label="Nuevo reporte" />

    <fragment
        android:id="@+id/editReportFragment"
        android:name="com.example.romero.proyectofinalappsmoviles.ui.reports.EditReportFragment"
        android:label="Editar reporte">
        <argument
            android:name="reportId"
            app:argType="long" />
    </fragment>

    <fragment
        android:id="@+id/syncStatusFragment"
        android:name="com.example.romero.proyectofinalappsmoviles.ui.sync.SyncStatusFragment"
        android:label="Sincronización" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.romero.proyectofinalappsmoviles.ui.settings.SettingsFragment"
        android:label="Ajustes" />

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.romero.proyectofinalappsmoviles.ui.login.LoginFragment"
        android:label="Login">
        <action
            android:id="@+id/action_login_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.romero.proyectofinalappsmoviles.ui.profile.ProfileFragment"
        android:label="Perfil">
        <action
            android:id="@+id/action_profile_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

</navigation>